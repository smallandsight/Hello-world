# ============================================
# 古月租车后端服务 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 应用基础配置 ---
NODE_ENV=development
APP_PORT=3000
APP_NAME=gy-bike-server
API_PREFIX=/v1

# --- CORS 配置 ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- MySQL 数据库配置 (TypeORM) ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DATABASE=gy_bike
DB_CHARSET=utf8mb4
DB_TIMEZONE=+08:00
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_ENTITIES=src/modules/**/*.entity.ts
DB_MIGRATIONS=src/database/migrations/*.ts
DB_MIGRATIONS_RUN=false

# --- Redis 缓存配置 ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=gy:bike:
REDIS_CONNECT_TIMEOUT=10000
REDIS_MAX_RETRIES=3

# --- JWT 认证配置 ---
JWT_SECRET=your_jwt_secret_key_change_in_production_min_32_chars
JWT_USER_EXPIRES_IN=7d      # 用户端Token有效期（7天）
JWT_STAFF_EXPIRES_IN=2d     # 商家端Token有效期（2天）
JWT_REFRESH_EXPIRES_IN=30d  # RefreshToken有效期（30天）
JWT_ISSUER=gy-bike-api

# --- 支付宝小程序配置 ---
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# --- 日志配置 ---
LOG_LEVEL=debug

# --- Swagger 文档 ---
SWAGGER_TITLE=古月租车 API
SWAGGER_DESCRIPTION=古月租车小程序后端接口文档
SWAGGER_VERSION=1.0.0
