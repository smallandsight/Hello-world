# ============================================================
# 古月租车 - 环境配置模板
# 复制此文件为 .env 并填写真实值
# ============================================================

# ==================== 基础配置 ====================
NODE_ENV=development
APP_PORT=3000
API_PREFIX=/v1
APP_NAME=gy-bike-server
LOG_LEVEL=debug

# ==================== 数据库 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DATABASE=gy_bike
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_TIMEZONE=+08:00

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_USER_EXPIRES_IN=7d
JWT_STAFF_EXPIRES_IN=2d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=gy-bike-api

# ==================== 支付宝 (Alipay) ====================
# 获取方式：https://open.alipay.com/platform/appManage
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END RSA PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_SANDBOX=false
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1

# ==================== 阿里云短信 (SMS) ====================
# 获取方式：https://dysms.console.aliyun.com/
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=古月租车
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# 短信模板Code（需要在阿里云控制台申请审核）
ALIPAY_SMS_TEMPLATE_VERIFY_CODE=SMS_XXXXXXXX  # 验证码模板
ALIPAY_SMS_TEMPLATE_ORDER_CREATED=SMS_XXXXXXXX # 订单创建通知
ALIPAY_SMS_TEMPLATE_PICKUP_REMINDER=SMS_XXXXXXXX
ALIPAY_SMS_TEMPLATE_RETURN_REMINDER=SMS_XXXXXXXX
ALIPAY_SMS_TEMPLATE_PAYMENT_SUCCESS=SMS_XXXXXXXX
ALIPAY_SMS_TEMPLATE_REFUND_NOTICE=SMS_XXXXXXXX

# ==================== 阿里云 OSS (文件存储) ====================
# 获取方式：https://oss.console.aliyun.com/
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=gy-bike-assets
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com  # 可选，默认按region拼接
OSS_PRIVATE=false
OSS_CUSTOM_DOMAIN=cdn.gy-bike.com  # 可选，自定义CDN域名

# ==================== 高德地图 (AMap) ====================
# 获取方式：https://console.amap.com/dev/key/app
AMAP_WEB_API_KEY=your_amap_web_api_key
